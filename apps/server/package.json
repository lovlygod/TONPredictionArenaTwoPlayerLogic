{
  "name": "@arena/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsup src/main.ts --format esm --dts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "prisma db push",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "balance": "tsx src/cli/balance.ts"
  },
  "dependencies": {
    "@arena/shared": "workspace:*",
    "@prisma/client": "^6.4.1",
    "@ton/ton": "13.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "nanoid": "^5.1.2",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "ton-core": "0.53.0",
    "ton-crypto": "3.2.0",
    "ws": "^8.18.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "@types/ws": "^8.5.14",
    "prisma": "^6.4.1",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
